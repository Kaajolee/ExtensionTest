{
  "manifest_version": 3,
  "name": "Chat Monitor",
  "version": "1.0.0",
  "description": "Chrome extension for monitoring chat response times.",
  "permissions": ["scripting", "activeTab", "tabs", "storage", "alarms"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Chat Monitor",
    "default_icon": {
      "32": "icon-light-32x32.png"
    }
  },
  "icons": {
    "32": "icon-light-32x32.png"
  },
  "content_scripts": [
    {
      "matches": ["https://*/hc/agent/*", "https://*.zendesk.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; base-uri 'self'; frame-ancestors 'none'"
  }
}
