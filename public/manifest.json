{
  "manifest_version": 3,
  "name": "Chat Monitor",
  "version": "1.0.0",
  "description": "Chrome extension for monitoring chat response times.",
  "permissions": ["scripting", "activeTab", "tabs"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Chat Monitor",
    "default_icon": {
      "32": "icon-light-32x32.png"
    }
  },
  "icons": {
    "32": "icon-light-32x32.png"
  }
}
